{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "printer-monitor",
  "version": "0.1.0",
  "identifier": "com.codicore.printer-monitor",
  "build": {
    "frontendDist": "../dist/printer-monitor/browser",
    "devUrl": "http://localhost:9002",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Printer Monitor",
        "width": 900,
        "height": 650,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "libs/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  }
}
