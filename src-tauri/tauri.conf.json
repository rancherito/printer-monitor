{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "printer-monitor",
  "version": "0.1.0",
  "identifier": "com.codicore.printer-monitor",
  "build": {
    "frontendDist": "../dist/printer-monitor/browser",
    "devUrl": "http://localhost:9002",
    "beforeDevCommand": "bun run start",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Printer Monitor",
        "width": 900,
        "height": 650,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/pdfium.dll"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {}
  }
}
