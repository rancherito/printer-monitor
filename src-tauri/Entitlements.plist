<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Permite que la app inicie conexiones de red salientes -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- Permite que la app acepte conexiones de red entrantes (servidor local) -->
  <key>com.apple.security.network.server</key>
  <true/>
  <!-- Permite acceso a archivos del usuario (necesario para CUPS) -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
  <!-- Deshabilita sandbox de App Store para permitir comandos de sistema -->
  <key>com.apple.security.app-sandbox</key>
  <false/>
</dict>
</plist>
